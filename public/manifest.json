{
    "manifest_version": 3,
    "name": "Screen Translator (Yandex)",
    "version": "1.0.0",
    "permissions": ["activeTab", "storage", "scripting", "offscreen"],
    "host_permissions": ["<all_urls>", "https://vision.yandex.net/*", "https://translate.yandex.net/*"],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["content.css", "offscreen.html"],
            "matches": ["<all_urls>"]
        }
    ]
}
